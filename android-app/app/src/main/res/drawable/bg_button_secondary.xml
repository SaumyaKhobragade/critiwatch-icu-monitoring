<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_secondary" />
            <stroke
                android:width="@dimen/border_width"
                android:color="@color/border_color" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/soft_blue" />
            <stroke
                android:width="@dimen/border_width"
                android:color="@color/secondary_accent" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_card" />
            <stroke
                android:width="@dimen/border_width"
                android:color="@color/border_color" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>
</selector>
