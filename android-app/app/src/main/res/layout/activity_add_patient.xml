<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.example.critiwatch.AddPatientActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="@dimen/spacing_lg">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_primary" />

            <TextView
                android:id="@+id/tvAddPatientTitle"
                style="@style/TextAppearance.CritiWatch.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:text="Add New Patient"
                android:textSize="@dimen/text_subhead"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivBack"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <LinearLayout
                android:id="@+id/btnScanWristband"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:background="@drawable/bg_section_soft"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/primary_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan Patient Wristband"
                    android:textColor="@color/primary_accent"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                style="@style/Widget.CritiWatch.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:text="Patient Information"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_subhead"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etPatientName"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_edit_text"
                        android:hint="e.g. John Doe"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient ID / MRN"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etPatientId"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_edit_text"
                        android:hint="e.g. P-123456"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_edit_text"
                        android:hint="Years"
                        android:inputType="number"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sex"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerSex"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:background="@drawable/bg_edit_text"
                        android:paddingHorizontal="@dimen/spacing_md" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                style="@style/Widget.CritiWatch.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:text="Admission Details"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_subhead"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ward / Unit"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerWard"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_edit_text"
                        android:paddingHorizontal="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bed Number"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etBedNumber"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_edit_text"
                        android:hint="e.g. ICU-04"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Primary Diagnosis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDiagnosis"
                        android:layout_width="match_parent"
                        android:layout_height="88dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:background="@drawable/bg_edit_text"
                        android:gravity="top"
                        android:hint="Enter diagnosis..."
                        android:inputType="textMultiLine"
                        android:padding="@dimen/spacing_md"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                style="@style/Widget.CritiWatch.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xxl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:text="Initial Vitals (Optional)"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_subhead"
                        android:textStyle="bold" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:useDefaultMargins="true">

                        <EditText
                            android:id="@+id/etHeartRate"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_edit_text"
                            android:hint="Heart Rate (BPM)"
                            android:inputType="number"
                            android:paddingHorizontal="@dimen/spacing_md" />

                        <EditText
                            android:id="@+id/etSpO2"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_edit_text"
                            android:hint="SpO2 (%)"
                            android:inputType="number"
                            android:paddingHorizontal="@dimen/spacing_md" />

                        <EditText
                            android:id="@+id/etSystolicBP"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_edit_text"
                            android:hint="Systolic BP (mmHg)"
                            android:inputType="number"
                            android:paddingHorizontal="@dimen/spacing_md" />

                        <EditText
                            android:id="@+id/etDiastolicBP"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_edit_text"
                            android:hint="Diastolic BP (mmHg)"
                            android:inputType="number"
                            android:paddingHorizontal="@dimen/spacing_md" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnRegisterPatient"
                style="@style/Widget.CritiWatch.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/spacing_md"
                android:text="Register Patient"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCancel"
                style="@style/Widget.CritiWatch.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Cancel"
                android:textAllCaps="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

