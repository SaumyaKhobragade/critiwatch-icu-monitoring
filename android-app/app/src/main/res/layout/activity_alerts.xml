<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/background"
    tools:context="com.example.critiwatch.AlertsActivity">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvAlertsTitle"
                style="@style/TextAppearance.CritiWatch.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clinical Alerts"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvAlertCountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_critical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="3 Active"
                android:textColor="@color/status_critical"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filters -->
    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_secondary"
        android:paddingVertical="@dimen/spacing_sm"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_button_primary"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="All"
                android:textColor="@color/inverse_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterCritical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_chip_neutral"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Critical"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_chip_neutral"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Warning"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterAcknowledged"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_neutral"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Acknowledged"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Alerts List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_lg"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/filterScrollView"
        tools:listitem="@layout/item_alert" />

    <!-- Bottom Navigation Placeholder -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        style="@style/Widget.CritiWatch.BottomNavigation"
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_navigation"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/menu_bottom_navigation" />

</androidx.constraintlayout.widget.ConstraintLayout>



