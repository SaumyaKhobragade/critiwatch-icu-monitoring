<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/background"
    tools:context="com.example.critiwatch.NotificationDetailActivity">

    <!-- Alert Header Area -->
    <LinearLayout
        android:id="@+id/llAlertHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/soft_red"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xxl"
        app:layout_constraintBottom_toTopOf="@+id/cvNotificationContent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start"
            android:contentDescription="Back"
            android:src="@drawable/ic_action_back"
            android:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvAlertIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="🚨"
            android:textSize="80sp" />

        <TextView
            android:id="@+id/tvAlertTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:maxLines="2"
            android:text="CRITICAL ALERT"
            android:textColor="@color/status_critical"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAlertSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Monitoring Alert"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvAlertDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:text="Alert details and response options are shown below."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Notification Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvNotificationContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llAlertHeader">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <!-- Patient Summary Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    app:cardBackgroundColor="@color/surface_secondary"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <TextView
                            android:id="@+id/tvPatientNameLarge"
                            style="@style/TextAppearance.CritiWatch.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sarah Johnson"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvPatientMetaLarge"
                            style="@style/TextAppearance.CritiWatch.Secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Bed ICU-04 • Female • 64y"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Alert Details / Parameters -->
                <TextView
                    style="@style/TextAppearance.CritiWatch.Header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:text="Alert Parameters"
                    android:textSize="@dimen/text_caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- HR Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_md"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Heart Rate"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvAlertHRValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="132 BPM"
                            android:textColor="@color/status_critical"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" />

                    <!-- SpO2 Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_md"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SpO2"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvAlertSpO2Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="86%"
                            android:textColor="@color/status_critical"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" />

                    <!-- BP Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_md"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Blood Pressure"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvAlertBPValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85/55 mmHg"
                            android:textColor="@color/status_critical"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" />

                    <!-- Confidence Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_md"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Prediction Confidence"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvAlertConfidenceValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="88%"
                            android:textColor="@color/primary_accent"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnEscalateAlert"
                        style="@style/Widget.CritiWatch.Button.Danger"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:text="Escalate Alert"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnViewPatientProfile"
                        style="@style/Widget.CritiWatch.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:text="Open Patient Details" />

                    <Button
                        android:id="@+id/btnAcknowledgeAlert"
                        style="@style/Widget.CritiWatch.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:text="Acknowledge Alert" />

                    <Button
                        android:id="@+id/btnDismissAlert"
                        style="@style/Widget.CritiWatch.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="Dismiss" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>


