<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.CritiWatch.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <View
            android:id="@+id/viewSeverityIndicator"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/status_critical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSeverityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:background="@drawable/bg_chip_critical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="CRITICAL"
            android:textColor="@color/status_critical"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/viewSeverityIndicator"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvAlertTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="2m ago"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            app:layout_constraintBaseline_toBaselineOf="@id/tvSeverityBadge"
            app:layout_constraintStart_toEndOf="@id/tvSeverityBadge" />

        <TextView
            android:id="@+id/tvAlertValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="142"
            android:textColor="@color/status_critical"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvAlertUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/tvAlertValue"
            app:layout_constraintTop_toBottomOf="@id/tvAlertValue" />

        <TextView
            android:id="@+id/tvAlertType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Sustained Tachycardia"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvAlertValue"
            app:layout_constraintStart_toEndOf="@id/viewSeverityIndicator"
            app:layout_constraintTop_toBottomOf="@id/tvSeverityBadge" />

        <TextView
            android:id="@+id/tvAlertPatientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="2dp"
            android:text="Patient ID: ICU-40-42-B"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvAlertValue"
            app:layout_constraintStart_toEndOf="@id/viewSeverityIndicator"
            app:layout_constraintTop_toBottomOf="@id/tvAlertType" />

        <TextView
            android:id="@+id/tvAlertDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Heart rate exceeded threshold for over 5 minutes. Immediate bedside review recommended."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewSeverityIndicator"
            app:layout_constraintTop_toBottomOf="@id/tvAlertPatientName" />

        <LinearLayout
            android:id="@+id/alertActionRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewSeverityIndicator"
            app:layout_constraintTop_toBottomOf="@id/tvAlertDescription">

            <Button
                android:id="@+id/btnOpenPatientFile"
                style="@style/Widget.CritiWatch.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:gravity="center"
                android:maxLines="1"
                android:text="Patient Details"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <Space
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnMarkResolved"
                style="@style/Widget.CritiWatch.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:gravity="center"
                android:maxLines="1"
                android:text="Mark Resolved"
                android:textAllCaps="false"
                android:textColor="@color/inverse_text"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

