<resources>
    <style name="Base.Theme.CritiWatch" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/inverse_text</item>
        <item name="colorPrimaryContainer">@color/soft_blue</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/secondary_accent</item>
        <item name="colorOnSecondary">@color/inverse_text</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_color</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
        <item name="bottomNavigationStyle">@style/Widget.CritiWatch.BottomNavigation</item>
    </style>

    <style name="Theme.CritiWatch" parent="Base.Theme.CritiWatch" />
</resources>
