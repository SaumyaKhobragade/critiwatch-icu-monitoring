<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CritiWatch" parent="Theme.Material3.Light.NoActionBar">
        <!-- Brand -->
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/inverse_text</item>
        <item name="colorPrimaryContainer">@color/soft_blue</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/secondary_accent</item>
        <item name="colorOnSecondary">@color/inverse_text</item>
        <item name="colorSecondaryContainer">@color/soft_blue</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        <item name="colorTertiary">@color/info_accent</item>
        <item name="colorOnTertiary">@color/inverse_text</item>
        <item name="colorError">@color/status_critical</item>
        <item name="colorOnError">@color/inverse_text</item>
        <item name="colorErrorContainer">@color/soft_red</item>
        <item name="colorOnErrorContainer">@color/status_critical</item>

        <!-- Surfaces and typography -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_color</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/surface_secondary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:navigationBarColor">@color/surface_card</item>

        <!-- Component defaults -->
        <item name="bottomNavigationStyle">@style/Widget.CritiWatch.BottomNavigation</item>
    </style>

    <style name="Theme.CritiWatch" parent="Base.Theme.CritiWatch" />

    <!-- Card Style -->
    <style name="Widget.CritiWatch.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardUseCompatPadding">false</item>
    </style>

    <!-- Header Text Style -->
    <style name="TextAppearance.CritiWatch.Header" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Secondary Text Style -->
    <style name="TextAppearance.CritiWatch.Secondary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.CritiWatch.Button.Base" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.CritiWatch.Button" parent="Widget.CritiWatch.Button.Base">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/inverse_text</item>
    </style>

    <style name="Widget.CritiWatch.Button.Secondary" parent="Widget.CritiWatch.Button.Base">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.CritiWatch.Button.Danger" parent="Widget.CritiWatch.Button.Base">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/inverse_text</item>
    </style>

    <style name="Widget.CritiWatch.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item_colors</item>
        <item name="itemTextColor">@color/bottom_nav_item_colors</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.CritiWatch.BottomNavLabel</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.CritiWatch.BottomNavLabel</item>
        <item name="itemRippleColor">@color/secondary_accent</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemHorizontalTranslationEnabled">false</item>
        <item name="itemPaddingTop">3dp</item>
        <item name="itemPaddingBottom">1dp</item>
        <item name="itemIconSize">19dp</item>
        <item name="android:minHeight">60dp</item>
        <item name="android:background">@drawable/bg_bottom_navigation</item>
        <item name="android:elevation">8dp</item>
    </style>

    <style name="TextAppearance.CritiWatch.BottomNavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>
