<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CritiWatch" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_accent</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.CritiWatch" parent="Base.Theme.CritiWatch" />

    <!-- Card Style -->
    <style name="Widget.CritiWatch.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>

    <!-- Header Text Style -->
    <style name="TextAppearance.CritiWatch.Header" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Secondary Text Style -->
    <style name="TextAppearance.CritiWatch.Secondary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.CritiWatch.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CritiWatch.Button</item>
    </style>

    <style name="ShapeAppearance.CritiWatch.Button" parent="">
        <item name="cornerSize">@dimen/radius_md</item>
    </style>
</resources>